# Minimal deterministic kernel config fragment (bead guest-sdk-laj).
#
# Applied by image/build.sh over `make tinyconfig` via
# scripts/kconfig/merge_config.sh, then `make olddefconfig`. build.sh
# re-asserts every determinism-critical line below against the final .config
# and fails loudly if olddefconfig flipped any of them.
#
# Scope: CONFIG_* build options ONLY. The kernel cmdline is owned by
# determinism-hypervisor ARCHITECTURE.md §2.3 (see image/KERNEL.md and
# https://github.com/preestablished/guest-sdk/issues/1).

# ---- base machine: x86_64, single CPU, no ACPI surprises ----
CONFIG_64BIT=y
# CONFIG_SMP is not set
# CONFIG_NUMA is not set
# Deterministic layout: no KASLR, fixed physical load address.
# CONFIG_RANDOMIZE_BASE is not set
# CONFIG_RANDOMIZE_MEMORY is not set
# CONFIG_RELOCATABLE is not set

# ---- the determinism set (ARCHITECTURE.md §5 pinning requirements) ----
# No page migration, ever: mlocked PFNs must be stable for the life of a run.
# CONFIG_COMPACTION is not set
# CONFIG_MIGRATION is not set
# CONFIG_KSM is not set
# CONFIG_TRANSPARENT_HUGEPAGE is not set
# No swap device exists in the guest; remove the machinery entirely.
# CONFIG_SWAP is not set

# ---- memory publication ----
CONFIG_HUGETLBFS=y
# /proc/<pid>/pagemap for GVA->GPA self-translation (agent::translate).
CONFIG_PROC_FS=y
CONFIG_PROC_PAGE_MONITOR=y
CONFIG_SYSFS=y

# ---- retired-instruction counting (M2 icount gate) ----
CONFIG_PERF_EVENTS=y

# ---- boot path: initramfs /init (the agent), devtmpfs ----
CONFIG_BLK_DEV_INITRD=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_BINFMT_ELF=y
CONFIG_SHMEM=y
CONFIG_MULTIUSER=y

# ---- detcall port I/O ----
# iopl(3) for the 0xD370-0xD39F detcall range (above ioperm's 0x3FF limit);
# tinyconfig disables the syscall entirely — without this the agent's first
# OUT is a GPF (found the hard way on first in-VM boot).
# CONFIG_MULTIUSER keeps Linux capability checks in place; the minimal image
# runs agent/workloads as root with CAP_SYS_RAWIO so iopl(3) and /dev/mem are
# viable while the lab guest remains trusted and isolated.
CONFIG_X86_IOPL_IOPERM=y

# ---- /dev/mem for the SDK's pv-pad MMIO window mapping (API.md §1, M3) ----
# Unrestricted (STRICT_DEVMEM off): the SDK maps a device GPA, not RAM, but
# the trusted lab guest does not need the filter at all.
CONFIG_DEVMEM=y
# CONFIG_STRICT_DEVMEM is not set

# ---- agent runtime needs (single-threaded epoll loop, Rust std) ----
CONFIG_EPOLL=y
CONFIG_SIGNALFD=y
CONFIG_TIMERFD=y
CONFIG_EVENTFD=y
CONFIG_FUTEX=y
# AF_UNIX for the agent IPC socket (socketpair(AF_UNIX, SOCK_SEQPACKET),
# ARCHITECTURE.md §4.2 / §5). Loopback-only — no devices, no external I/O —
# so it stays inside the §7 determinism envelope. CONFIG_UNIX requires NET.
CONFIG_NET=y
CONFIG_UNIX=y
# But no inet/packet families; nothing routes anywhere.
# CONFIG_INET is not set

# ---- timer model: periodic 100 Hz tick, pinned explicitly ----
# The READY-point icount depends on the tick model; do not inherit it from
# olddefconfig defaults. No NO_HZ, no hires timers, no paravirt clock.
CONFIG_HZ_PERIODIC=y
CONFIG_HZ_100=y
# CONFIG_NO_HZ_IDLE is not set
# CONFIG_NO_HZ_FULL is not set
# CONFIG_HIGH_RES_TIMERS is not set
# CONFIG_HYPERVISOR_GUEST is not set

# ---- serial console for harness debugging ----
# Output cost is deterministic (OUT instructions at deterministic icounts);
# the canonical image may silence it via the hypervisor-owned cmdline.
CONFIG_TTY=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_PRINTK=y

# ---- entropy: nothing hardware-backed; hypervisor virtualizes RDRAND ----
# CONFIG_HW_RANDOM is not set
